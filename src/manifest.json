{
  "manifest_version": 3,
  "name": "nvim-in-browser",
  "version": "0.0.0",
  "description": "Real Neovim (WASM) editing in browser text fields and a scratch page — no local Neovim required",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Neovim scratch page"
  },
  "commands": {
    "activate-nvim": {
      "suggested_key": { "default": "Ctrl+Shift+E", "mac": "MacCtrl+Shift+E" },
      "description": "Activate Neovim on the focused text field"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "engine-frame.html",
        "engine-frame.js",
        "engine-worker.js",
        "nvim-asyncify.wasm",
        "nvim-runtime.tar.gz"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
