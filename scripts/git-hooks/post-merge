#!/bin/sh
# post-merge: after a `git pull` (merge), keep the working tree's build current
# so the loaded extension is up to date. Activated via
# core.hooksPath=scripts/git-hooks, which the package.json "prepare" script sets
# on `npm install` / `npm ci`.
#
# Fires only on a MERGE-style pull, NOT `git pull --rebase`.
#
# Modeled on the chrome-intercept post-merge hook. Deliberately:
#   * `#!/bin/sh`, NO `set -e`/`pipefail` — a failed step must never stop the
#     build, and (critically) `pipefail` + `printf | grep -q` returns a false
#     negative on a LARGE diff (grep exits early, printf gets SIGPIPE), which
#     used to make big pulls silently skip the build.
#   * `case` for change detection (no pipe, no SIGPIPE).
#   * ALWAYS build — cheap and bulletproof vs. gating on a detection that can
#     misfire. Reinstalling deps / re-fetching the engine stays conditional.
#
# NOTE: git runs this hook without your login shell, so an nvm-managed `npm`
# must be on PATH. It is in a normal terminal; a GUI/IDE git client may not
# source your profile — pull from a terminal if the build doesn't run.

echo "[post-merge] pull complete — refreshing the extension build"

changed=$(git diff-tree -r --name-only --no-commit-id ORIG_HEAD HEAD 2>/dev/null || true)

# Reinstall deps only if they changed (best-effort; never blocks the build).
case "$changed" in
  *package-lock.json*|*package.json*)
    echo "[post-merge] dependencies changed — installing"
    npm ci --no-audit --no-fund \
      || npm install --no-audit --no-fund \
      || echo "[post-merge] dependency install failed — building with existing node_modules"
    ;;
esac

# Re-fetch the pinned nvim-wasi engine only if the lock changed (idempotent).
case "$changed" in
  *engine.lock.json*)
    echo "[post-merge] engine pin changed — npm run fetch-assets"
    npm run fetch-assets || echo "[post-merge] fetch-assets failed — run 'npm run fetch-assets' manually"
    ;;
esac

echo "[post-merge] running npm run build"
if npm run build; then
  echo "[post-merge] done — reload the extension at chrome://extensions (↻)"
else
  echo "[post-merge] BUILD FAILED — run 'npm run build' manually (is npm on PATH?)"
fi
