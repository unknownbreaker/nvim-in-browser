{
  "name": "nvim-in-browser",
  "version": "0.25.1",
  "private": true,
  "description": "Real Neovim (WASM) editing in browser text fields and a scratch page — no local Neovim required",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "fetch-assets": "node scripts/fetch-engine.mjs",
    "lint:firefox": "web-ext lint --source-dir dist/firefox --self-hosted --output text",
    "smoke:firefox": "node scripts/firefox-smoke.mjs",
    "smoke:firefox:behavioral": "node scripts/firefox-behavioral-smoke.mjs",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.worker.json",
    "prepare": "git config core.hooksPath scripts/git-hooks 2>/dev/null || true"
  },
  "dependencies": {
    "@bjorn3/browser_wasi_shim": "^0.4.2",
    "@johnnymorganz/stylua": "2.5.2",
    "@msgpack/msgpack": "^3.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/node": "^26.1.1",
    "esbuild": "^0.25.0",
    "puppeteer-core": "^25.3.0",
    "typescript": "^5.5.3",
    "vitest": "^2.0.0"
  }
}
