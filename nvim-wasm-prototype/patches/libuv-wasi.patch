# libuv-wasi.patch
#
# WHAT: Three small hunks against libuv v1.52.1 upstream sources that wire in
#       the wasm32-wasi platform port backed by shims/uv-wasi-*.c:
#         1. include/uv/unix.h: add a __wasi__ branch to the platform-select
#            ladder that pulls in uv/posix.h (the poll(2)-shaped platform loop
#            fields our poll_oneoff-based uv__io_poll shim needs).
#         2. src/random.c: add a __wasi__ dispatch branch to uv__random() that
#            calls uv__random_getentropy() (shims/uv-wasi-platform.c) instead
#            of the upstream /dev/urandom or dlsym-probed getentropy paths.
#         3. src/unix/core.c: exclude wasi-libc's emulated struct rusage from
#            the ru_maxrss/ru_ixrss/... field-copy block in uv_getrusage(),
#            since that emulation only carries ru_utime/ru_stime.
#
# WHY:  wasi-libc's headers declare a platform wasm32-wasi never appears in
#       upstream's own #if ladders (unix.h's OS list, random.c's per-OS
#       dispatch), so without these hunks the port either fails to compile
#       (no uv/posix.h fields on this target) or compiles against upstream
#       code paths (/dev/urandom, full struct rusage) that do not exist under
#       WASI preview1. Each hunk is the minimal, targeted addition needed to
#       route this one platform through the shim layer without touching any
#       other platform's behavior.
#
# CLEAN-ROOM PROVENANCE: authored from first principles against libuv v1.52.1
#       upstream source (MIT, vendored in src-cache/libuv), the WASI preview1
#       spec (random_get, absence of /dev/urandom and full rusage), and this
#       port's own shims/uv-wasi-platform.c + shims/uv-wasi-poll.c (which this
#       patch's hunks exist to wire up). No excluded project (MuNeNICK/nvim-wasm
#       or MuNeNICK/monaco-neovim-wasm) was consulted.
#
# Apply with: patch -p1 < patches/libuv-wasi.patch   (from the libuv source root)
--- a/include/uv/unix.h	2026-07-15 00:46:03
+++ b/include/uv/unix.h	2026-07-15 00:46:48
@@ -67,6 +67,10 @@
       defined(__HAIKU__)  || \
       defined(__QNX__)    || \
       defined(__GNU__)
+# include "uv/posix.h"
+#elif defined(__wasi__)
+/* wasm32-wasi port (nvim-wasm-prototype): the poll(2)-shaped platform loop
+ * fields from uv/posix.h back our poll_oneoff-based uv__io_poll shim. */
 # include "uv/posix.h"
 #endif
 
--- a/src/random.c	2026-07-15 00:46:06
+++ b/src/random.c	2026-07-15 00:46:51
@@ -62,6 +62,11 @@
 #elif defined(_WIN32)
   uv__once_init();
   rc = uv__random_winrandom(buf, buflen);
+#elif defined(__wasi__)
+  /* wasm32-wasi port (nvim-wasm-prototype): no /dev/urandom in the WASI
+   * sandbox; getentropy() maps to WASI random_get (shim provides
+   * uv__random_getentropy without the upstream dlsym() probe). */
+  rc = uv__random_getentropy(buf, buflen);
 #else
   rc = uv__random_devurandom(buf, buflen);
 #endif
--- a/src/unix/core.c	2026-07-15 01:57:40
+++ b/src/unix/core.c	2026-07-15 01:58:06
@@ -1106,7 +1106,9 @@
   rusage->ru_stime.tv_sec = usage.ru_stime.tv_sec;
   rusage->ru_stime.tv_usec = usage.ru_stime.tv_usec;
 
-#if !defined(__MVS__) && !defined(__HAIKU__)
+/* wasm32-wasi port (nvim-wasm-prototype): wasi-libc's emulated
+ * struct rusage only carries ru_utime/ru_stime. */
+#if !defined(__MVS__) && !defined(__HAIKU__) && !defined(__wasi__)
   rusage->ru_maxrss = usage.ru_maxrss;
   rusage->ru_ixrss = usage.ru_ixrss;
   rusage->ru_idrss = usage.ru_idrss;
