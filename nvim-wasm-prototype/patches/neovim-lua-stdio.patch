# patches/neovim-lua-stdio.patch
#
# WHAT: Under __wasi__, divert Lua's stdio output surface (the default io
# output that io.write() targets, plus the io.stdout handle) to stderr,
# immediately after the embedded Lua state opens its standard libraries in
# nlua_init().
#
# WHY: The companion patches/neovim-embed-stdio.patch keeps the msgpack-RPC
# channel directly on fds 0/1 (WASI preview1 has no fd-duplication primitive
# to move it). Neovim's own RPC writes are raw uv fd writes and are fine, but
# Lua's io library writes through C stdio FILE* stdout — i.e. straight into
# fd 1. That was empirically fatal: 3 bytes of user-Lua io.write() output
# (0xdc 0x00 0x10, a bare msgpack array16 header) permanently desynced the
# RPC framing and killed the session (see STATUS.md, Task 7 + Parity Task 2).
#
# MECHANISM (Lua-level redirect — chosen over a C stdio retarget, which is
# unviable on this target; full investigation in STATUS.md Parity Task 2):
#   io.output(io.stderr)     -- io.write() writes to the DEFAULT output
#                            -- (liolib.c: g_write(L, getiofile(L, IO_OUTPUT)));
#                            -- io.output() is the documented retarget API
#   io.stdout = io.stderr    -- catches explicit io.stdout:write(...)
# Deliberately NOT wrapping io.write itself: with the default output
# retargeted, a wrapper adds no protection and would break the legitimate
# `io.output(file); io.write(...)` pattern. print() needs no fix — nvim
# replaces it with nlua_print (message system, never fd 1).
#
# INJECTION POINT: nlua_init() right after luaL_openlibs() — the birth of the
# `io` table in the single embedded main-thread state, before any Lua code
# (runtime or user) can run. Thread states are unreachable under WASI
# (uv_thread_create = ENOSYS) and `nvim -l` script states are not the
# embedded RPC path, so patching nlua_init alone is sufficient and minimal.
#
# CLEAN-ROOM PROVENANCE: derived solely from Neovim v0.12.4 sources
# (src/nvim/lua/executor.c, vendored in src-cache/neovim), PUC Lua 5.1.5
# sources (src/liolib.c, vendored in src-cache/lua), and the pinned
# wasi-sdk-33 sysroot headers (stdio.h). No excluded project
# (MuNeNICK/nvim-wasm or monaco-neovim-wasm) was consulted in any form.
#
--- a/src/nvim/lua/executor.c
+++ b/src/nvim/lua/executor.c
@@ -885,6 +885,18 @@
     os_exit(1);
   }
   luaL_openlibs(lstate);
+#ifdef __wasi__
+  // The msgpack-RPC channel lives directly on fds 0/1 (see
+  // patches/neovim-embed-stdio.patch), and Lua's io library writes through
+  // C stdio FILE* stdout = fd 1, so user Lua io.write()/io.stdout:write()
+  // would corrupt the RPC framing. Divert the default io output (io.write's
+  // target) and the io.stdout handle to stderr before any Lua code runs.
+  // print() is unaffected: nvim replaces it with nlua_print below.
+  if (luaL_dostring(lstate, "io.output(io.stderr) io.stdout = io.stderr")) {
+    fprintf(stderr, _("E970: Failed to divert Lua stdio to stderr\n"));
+    os_exit(1);
+  }
+#endif
   if (!nlua_state_init(lstate)) {
     fprintf(stderr, _("E970: Failed to initialize builtin Lua modules\n"));
 #ifdef EXITFREE
