# patches/neovim-embed-stdio.patch
#
# WHAT: The first (and only) genuine Neovim source patch of this port: skip
# the --embed stdio redirect in channel_from_stdio() when compiling for WASI.
#
# WHY: On POSIX, embedded nvim moves the RPC fds away from 0/1 with
# fcntl(F_DUPFD_CLOEXEC) and then points fds 0/1 at stderr with dup2(), so
# that (a) child processes never inherit the UI channel fds and (b) stray
# writes to stdout cannot corrupt the msgpack-RPC stream. WASI preview1 has
# no fd-duplication primitive at all (fd_renumber MOVES an fd; there is no
# dup), so fcntl(F_DUPFD_CLOEXEC) fails under wasi-libc and the channel
# would be initialized with fd -1 — the rung-5 blocker recorded in
# STATUS.md. The redirect simply cannot be implemented under preview1, so
# keeping fds 0/1 as the channel endpoints is the only option available —
# not a judgment call that the redirect's purposes don't apply here.
#
# KNOWN LIMITATION (do not remove this note without re-verifying): purpose
# (b) above is NOT moot inside the sandbox. It was empirically disproved —
# a user Lua `io.write()` call writes straight to fd 1, and 3 bytes of
# io.write() output permanently desynced the msgpack-RPC framing and killed
# the RPC session in testing. Purpose (a) (hiding the fds from child
# processes) is genuinely moot — preview1 has no child processes — but (b)
# is real and unaddressed by this patch. This is still an ACCEPTABLE gap
# for the current prototype gate, which runs nvim -u NORC --noplugin (no
# user Lua ever executes). It becomes a hard blocker before any milestone
# that runs user configs: a Lua-level redirect of `io.write`/`io.stdout`
# (and `print`, which routes through them) to stderr, or to a host-provided
# sink, must be installed before user Lua can run. A new #elif
# defined(__wasi__) branch keeps fds 0/1 as the channel endpoints, which is
# exactly what the wasm host wires up.
#
# Alternatives considered and rejected: implementing F_DUPFD in the shim
# layer is impossible to do honestly (fd_renumber invalidates the source
# fd; faking an alias fd would require intercepting every subsequent
# read/write/poll/close at the libc boundary).
#
# CLEAN-ROOM PROVENANCE: derived solely from Neovim v0.12.4 sources
# (src/nvim/channel.c, vendored in src-cache/neovim), the WASI preview1
# spec (fd_renumber semantics), and wasi-libc's fcntl implementation. No
# excluded project (MuNeNICK/nvim-wasm or monaco-neovim-wasm) was consulted
# in any form.
#
--- a/src/nvim/channel.c
+++ b/src/nvim/channel.c
@@ -581,6 +581,11 @@
     os_replace_stdin_to_conin();
     os_replace_stdout_and_stderr_to_conout();
   }
+#elif defined(__wasi__)
+  // WASI preview1 has no dup()/F_DUPFD (fd_renumber MOVES an fd; there is no
+  // way to duplicate one), so the redirect below is impossible; the RPC
+  // channel stays on fds 0/1. KNOWN LIMITATION: anything else that writes to
+  // fd 1 (e.g. user Lua io.write()) corrupts the msgpack-RPC stream.
 #else
   if (embedded_mode) {
     // Redirect stdout/stdin (the UI channel) to stderr. Use fnctl(F_DUPFD_CLOEXEC) instead of dup()
