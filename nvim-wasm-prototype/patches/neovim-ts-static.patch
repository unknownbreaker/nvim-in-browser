# patches/neovim-ts-static.patch
#
# WHAT: Under __wasi__, pre-register the statically linked tree-sitter
# parsers (7 grammars: c, lua, vim, vimdoc, query, markdown,
# markdown_inline) into treesitter.c's process-global language map at
# tslua_init() time, from the {name, constructor} table exported by
# shims/nvim-wasi-treesitter.c.
#
# WHY: WASI has no dynamic loading. Upstream v0.12.4 resolves parsers
# EXCLUSIVELY through uv_dlopen(parser/<lang>.so) + uv_dlsym
# (load_language_from_object); the only other path, HAVE_WASMTIME's
# _ts_add_language_from_wasm, is also file-based (reads a .wasm parser blob
# from disk into a wasm store) and is OFF in this build. There is no
# upstream API that accepts an in-process TSLanguage*, and the `langs` map
# is file-static — so a minimal in-file registration hook is the only
# option that avoids touching the packaged runtime Lua.
#
# MECHANISM: vim.treesitter.language.add() (runtime/lua/vim/treesitter/
# language.lua) checks vim._ts_has_language(lang) FIRST and returns true
# before any parser-file lookup. Pre-populating the map therefore makes
# language.add('<lang>') succeed through the untouched upstream fast path —
# no runtime-Lua modification, no dummy parser files. The hunk mirrors
# add_language()'s ABI-version validation (skip + loud stderr line instead
# of luaL_error, since this runs during state init); the map_has() guard
# keeps re-initialization idempotent. Registration is 7 map inserts; the
# generated constructors just return pointers to static tables (no timers,
# no fds — the idle-wakeups property is unaffected).
#
# CLEAN-ROOM PROVENANCE: derived solely from Neovim v0.12.4 sources
# (src/nvim/lua/treesitter.c, runtime/lua/vim/treesitter/language.lua,
# vendored in src-cache/neovim) and the pinned tree-sitter sources. No
# excluded project (MuNeNICK/nvim-wasm or monaco-neovim-wasm) was consulted
# in any form.
#
--- a/src/nvim/lua/treesitter.c
+++ b/src/nvim/lua/treesitter.c
@@ -63,6 +63,19 @@
 #include "lua/treesitter.c.generated.h"

 static PMap(cstr_t) langs = MAP_INIT;
+
+#ifdef __wasi__
+// Statically linked tree-sitter parsers (no dlopen under WASI). The table
+// lives in shims/nvim-wasi-treesitter.c; tslua_init() walks it to
+// pre-register every grammar, so vim.treesitter.language.add() succeeds via
+// the vim._ts_has_language() fast path without a parser/<lang>.so file.
+typedef struct {
+  const char *name;
+  const TSLanguage *(*fn)(void);
+} NvimWasiTsStaticLang;
+extern const NvimWasiTsStaticLang nvim_wasi_ts_static_langs[];
+extern const size_t nvim_wasi_ts_static_langs_count;
+#endif

 #ifdef HAVE_WASMTIME
 static wasm_engine_t *wasmengine;
@@ -1783,6 +1796,34 @@
   build_meta(L, TS_META_QUERYMATCH, querymatch_meta);

   ts_set_allocator(xmalloc, xcalloc, xrealloc, xfree);
+
+#ifdef __wasi__
+  // Pre-register the statically linked parsers (see the table decl at the
+  // top of this file). Mirrors add_language()'s ABI validation; the langs
+  // map is process-global, so a re-init re-walks the table as a no-op.
+  for (size_t i = 0; i < nvim_wasi_ts_static_langs_count; i++) {
+    const NvimWasiTsStaticLang *e = &nvim_wasi_ts_static_langs[i];
+    if (map_has(cstr_t, &langs, e->name)) {
+      continue;
+    }
+    const TSLanguage *lang = e->fn();
+    if (lang == NULL) {
+      fprintf(stderr, "nvim-wasi: static tree-sitter parser '%s' returned NULL\n",
+              e->name);
+      continue;
+    }
+    uint32_t lang_version = ts_language_abi_version(lang);
+    if (lang_version < TREE_SITTER_MIN_COMPATIBLE_LANGUAGE_VERSION
+        || lang_version > TREE_SITTER_LANGUAGE_VERSION) {
+      fprintf(stderr,
+              "nvim-wasi: skipping static tree-sitter parser '%s': ABI %u not in [%d, %d]\n",
+              e->name, (unsigned)lang_version,
+              TREE_SITTER_MIN_COMPATIBLE_LANGUAGE_VERSION, TREE_SITTER_LANGUAGE_VERSION);
+      continue;
+    }
+    pmap_put(cstr_t)(&langs, xstrdup(e->name), (TSLanguage *)lang);
+  }
+#endif
 }

 static int tslua_get_language_version(lua_State *L)
